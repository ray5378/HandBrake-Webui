# HandBrake Web UI 环境变量示例
# 复制此文件为 .env 并修改相应值

# 服务配置
PORT=52389
NODE_ENV=production

# JWT 配置
# 生产环境请使用 openssl rand -base64 64 生成随机密钥
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 转码配置
MAX_CONCURRENT_JOBS=2

# 配置目录
CONFIG_DIR=/config

# 日志级别（ERROR, WARN, INFO, DEBUG）
LOG_LEVEL=INFO
