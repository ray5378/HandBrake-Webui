# HandBrake Web UI 环境变量示例
# 复制此文件为 .env 并修改相应值

# 服务配置
PORT=3000
NODE_ENV=production

# 管理员账户（首次启动会自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# JWT 配置
# 生产环境请使用 openssl rand -base64 64 生成随机密钥
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 转码配置
MAX_CONCURRENT_JOBS=2

# 目录映射（Docker 中建议使用绝对路径）
UPLOAD_DIR=/source
OUTPUT_DIR=/output
CONFIG_DIR=/config

# 日志级别（ERROR, WARN, INFO, DEBUG）
LOG_LEVEL=INFO
